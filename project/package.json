{
  "name": "runnly-ai-mvp",
  "version": "0.1.0",
  "private": true,
  "description": "Full-stack Next.js app with chat UI and event-driven Runnly.AI backend.",
  "scripts": {
    "dev": "npm run frontend:dev",
    "build": "npm run frontend:build",
    "start": "npm run frontend:start",
    "lint": "npm run frontend:lint",
    "test": "vitest",
    "test:ui": "vitest --ui",
    "test:run": "vitest run",
    "test:coverage": "vitest run --coverage",
    "frontend:dev": "npm run --prefix ui dev",
    "frontend:build": "npm run --prefix ui build",
    "frontend:start": "npm run --prefix ui start",
    "frontend:lint": "npm run --prefix ui lint",
    "build:backend": "tsc -p tsconfig.backend.json && node scripts/copy-db-schema.mjs",
    "dev:backend": "ts-node index.ts",
    "dev:api": "ts-node api/index.ts",
    "dev:worker": "ts-node worker/index.ts",
    "start:backend": "node dist/index.js",
    "start:api": "node dist/api/index.js",
    "start:worker": "node dist/worker/index.js",
    "redis-mac": "redis-server",
    "redis": "C:\\Redis\\redis-server.exe"
  },
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "@types/express": "^5.0.6",
    "@types/pg": "^8.20.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "dotenv": "^16.6.1",
    "express": "^5.2.1",
    "lucide-react": "^0.542.0",
    "next": "^16.2.4",
    "openai": "^6.33.0",
    "pg": "^8.20.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "redis": "^4.7.1",
    "sqlite3": "^6.0.1"
  },
  "devDependencies": {
    "@types/node": "^24.6.0",
    "@types/react": "^18.3.23",
    "@types/react-dom": "^18.3.7",
    "@vitest/coverage-v8": "^4.1.5",
    "@vitest/ui": "^4.1.5",
    "autoprefixer": "^10.4.21",
    "eslint": "^8.57.1",
    "eslint-config-next": "^13.5.11",
    "postcss": "^8.5.6",
    "tailwind-merge": "^3.3.1",
    "tailwindcss": "^3.4.17",
    "ts-node": "^10.9.2",
    "typescript": "^5.9.3",
    "vitest": "^4.1.5"
  }
}
