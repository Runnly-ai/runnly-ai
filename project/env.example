# HTTP API port
PORT=3000

# Worker dequeue timeout in milliseconds.
# Used by runtime loop when waiting for next command.
WORKER_POLL_MS=100

# Queue backend:
# - memory: in-process queue (single process/local)
# - redis: distributed queue using Redis list (RPUSH/BLPOP)
QUEUE_BACKEND=memory

# Event bus backend:
# - memory: in-process pub/sub
# - redis: distributed pub/sub via Redis channel
EVENT_BUS_BACKEND=memory

# State repository backend:
# - memory: in-process session/task/event/command stores
# - redis: shared Redis-backed stores across processes
STATE_BACKEND=memory

# Redis connection URL, used when any *_BACKEND is redis
REDIS_URL=redis://127.0.0.1:6379

# Prefix for Redis keys used by repos/queue/event bus.
# Useful for namespacing environments (dev/stage/prod).
REDIS_KEY_PREFIX=runnly-ai

# Redis list key used by command queue when QUEUE_BACKEND=redis
REDIS_COMMAND_QUEUE_KEY=runnly-ai:commands

# Redis pub/sub channel used by event bus when EVENT_BUS_BACKEND=redis
REDIS_EVENT_CHANNEL=runnly-ai:events

# Whether this process runs the worker runtime:
# - true: consumes commands and runs agents
# - false: does not run worker loop
RUN_WORKER=true

# Whether this process runs orchestration subscriber:
# - true: consumes events and dispatches next workflow commands
# - false: does not orchestrate
# For Redis pub/sub, run ONE orchestrator instance unless dedup/locking is added.
RUN_ORCHESTRATOR=true

# Enables verbose workflow progress logs from worker and orchestrator.
LOG_WORKFLOW_PROGRESS=false

# Enables verbose provider/agent debugging logs (tool calls, per-step model output, provider errors).
LOG_AGENT_DEBUG=false

# Persist per-session log entries into files under SESSION_LOG_DIR.
# Set to false to disable file sink.
LOG_SESSION_TO_FILE=true

# Directory for per-session log files (<sessionId>.log).
# Defaults to FACTORY_WORK_ROOT/logs/sessions.
SESSION_LOG_DIR=./.factory-work/logs/sessions

# Master switch to enable all verbose logging categories (workflow + agent/provider + SCM).
# When true, this overrides LOG_WORKFLOW_PROGRESS and LOG_AGENT_DEBUG.
LOG_VERBOSE=false

# Unified root for AI factory runtime artifacts (agent output, temporary workspace, SCM clones/worktrees).
FACTORY_WORK_ROOT=./.factory-work

# Optional override for LocalWorkspace temp area under FACTORY_WORK_ROOT.
# This path is fixed to FACTORY_WORK_ROOT/workspace.

# Database backend for persistent SCM binding storage:
# - sqlite: local file-backed database (default, recommended for local)
# - postgres: external Postgres database
DB_BACKEND=sqlite

# SQLite database file path used when DB_BACKEND=sqlite.
SQLITE_DB_PATH=./data/runnly-ai.sqlite

# Postgres URL used when DB_BACKEND=postgres.
# POSTGRES_URL=postgres://user:pass@localhost:5432/runnly-ai

# Optional directory for custom filesystem skills.
# Any nested file named SKILL.md will be discovered and loaded lazily.
# AGENT_SKILLS_DIR=./.skills

# Optional native LLM provider for executing filesystem skills.
# - none: parse/apply skill metadata only
# - openai: execute SKILL.md prompt with OpenAI Chat Completions
AGENT_LLM_PROVIDER=none

# Coder agent CLI provider.
# - codex
# - copilot
CODER_CLI_PROVIDER=codex

# =====================
# SIMPLIFIED AGENT CONFIG (RECOMMENDED)
# =====================
# Set these 3 variables for easy one-provider configuration:
# AGENT_PROVIDER: Which AI provider to use (openai | groq | deepseek | qwen | doubao | ollama | codex | copilot)
# AGENT_MODEL: Which model to use with that provider  
# AGENT_API_KEY: API key for the selected provider
#
# Example for OpenAI:
# AGENT_PROVIDER=openai
# AGENT_MODEL=gpt-4o-mini
# AGENT_API_KEY=sk-your-openai-key-here
#
# Example for Groq:
# AGENT_PROVIDER=groq
# AGENT_MODEL=llama-3.3-70b-versatile
# AGENT_API_KEY=gsk_your-groq-key-here
#
# Example for DeepSeek (cheap alternative):
# AGENT_PROVIDER=deepseek
# AGENT_MODEL=deepseek-chat
# AGENT_API_KEY=sk-your-deepseek-key
#
# Example for Doubao (Ark / Volcengine):
# AGENT_PROVIDER=doubao
# AGENT_MODEL=doubao-seed-2-0-code-preview-260215
# AGENT_API_KEY=your-ark-api-key
#
# Example for Ollama (free, local):
# AGENT_PROVIDER=ollama
# AGENT_MODEL=llama3.3
# AGENT_API_KEY=ollama
#
# These simplified settings automatically populate provider-specific configs below.
# If you need different providers per role, use the advanced config section.

AGENT_PROVIDER=
AGENT_MODEL=
AGENT_API_KEY=

# =====================
# ADVANCED AGENT CONFIG (OPTIONAL)
# =====================
# Use these for fine-grained control. These override the simplified settings above.

# Provider-specific API keys (OPTIONAL - use AGENT_API_KEY instead unless you need multiple providers)
# OPENAI_API_KEY=
# OPENAI_MODEL=gpt-4.1-mini
# GROQ_API_KEY=
# GROQ_MODEL=llama-3.3-70b-versatile
# DEEPSEEK_API_KEY=
# DEEPSEEK_MODEL=deepseek-chat
# QWEN_API_KEY=
# QWEN_MODEL=qwen3-max
# DOUBAO_API_KEY=
# DOUBAO_MODEL=doubao-seed-2-0-code-preview-260215
# OLLAMA_API_KEY=ollama
# OLLAMA_MODEL=qwen3-vl:8b

# Role-agent provider defaults (plan/generate/verify/review).
# Providers: codex | copilot | openai | groq | deepseek | qwen | doubao | ollama
AGENT_PROVIDER_DEFAULT=codex
# AGENT_PROVIDER_PLAN=
# AGENT_PROVIDER_GENERATE=
# AGENT_PROVIDER_VERIFY=
# AGENT_PROVIDER_REVIEW=
# AGENT_PROVIDER_INTAKE=openai

# Optional global model override for all role agents + intake.
# Per-role values below take precedence when set.
# AGENT_MODEL_DEFAULT=gpt-4.1-mini

# Optional per-role model overrides.
# AGENT_MODEL_PLAN=
# AGENT_MODEL_GENERATE=
# AGENT_MODEL_VERIFY=
# AGENT_MODEL_REVIEW=
# AGENT_MODEL_INTAKE=gpt-4.1-mini

# Max number of tool-calling loop steps per LLM provider run.
# Default is 20.
AGENT_MAX_TOOL_STEPS=20

# Max number of iterations (think-act cycles) for role loop agents.
# Default is 10. Planning agent uses this value.
AGENT_MAX_ITERATIONS=10

# Default working directory for coder-agent and tool-based role-agent runs.
# Fixed to FACTORY_WORK_ROOT/agent-cwd.
# Per-command payload `cwd` can still override at runtime.

# Codex CLI executable path used when CODER_CLI_PROVIDER=codex.
CODEX_CLI_PATH=codex

# Base args passed before instruction text.
# Defaults to "exec".
CODEX_CLI_BASE_ARGS=exec

# Optional model override when CODER_CLI_PROVIDER=codex.
# CODEX_MODEL=gpt-5.4-codex

# Copilot CLI executable path used when CODER_CLI_PROVIDER=copilot.
COPILOT_CLI_PATH=copilot

# Base args passed before instruction text for Copilot CLI.
COPILOT_CLI_BASE_ARGS=exec

# Optional model override when CODER_CLI_PROVIDER=copilot.
# COPILOT_MODEL=gpt-4.1

# Gemini CLI executable path used when CODER_CLI_PROVIDER=gemini or AGENT_PROVIDER=gemini.
# Default uses 'aichat' (https://github.com/sigoden/aichat) with Gemini backend.
# Alternative: Use Google's official Gemini CLI if available.
GEMINI_CLI_PATH=aichat

# Base args passed before instruction text for Gemini CLI.
# For aichat: '--model gemini' (or '--model gemini:gemini-2.0-flash-exp')
# Defaults to '--model gemini'.
GEMINI_CLI_BASE_ARGS=--model gemini

# Optional model override when CODER_CLI_PROVIDER=gemini.
# For aichat with Gemini: gemini-2.0-flash-exp, gemini-1.5-pro, etc.
# GEMINI_MODEL=gemini-2.0-flash-exp

# SCM module runtime settings (orchestration-owned, outside agent runtime):
# - git executable path
SCM_GIT_PATH=git

# Default target base branch when session.context.scm.baseBranch is not set.
SCM_DEFAULT_BASE_BRANCH=main

# Commit identity used for automated agent commits.
SCM_GIT_USER_NAME=runnly-ai
SCM_GIT_USER_EMAIL=runnly-ai@local

# Root directory for SCM clone/worktree state is fixed to FACTORY_WORK_ROOT/scm.

# Optional provider default tokens.
# Can be overridden by session.context.scm.token.
# SCM_GITHUB_TOKEN=
# SCM_AZURE_DEVOPS_TOKEN=

# Optional webhook verification secrets.
# If set, incoming webhook signatures are validated.
# SCM_GITHUB_WEBHOOK_SECRET=
# SCM_AZURE_DEVOPS_WEBHOOK_SECRET=
